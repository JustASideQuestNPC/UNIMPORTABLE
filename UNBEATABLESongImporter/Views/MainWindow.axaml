<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:viewModels="clr-namespace:UNBEATABLESongImporter.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="UNBEATABLESongImporter.Views.MainWindow"
        Width="750" Height="450"
        Title="UNIMPORTABLE"
        Background="{DynamicResource BackgroundPrimary}"
        x:DataType="viewModels:MainWindowViewModel"
        Focusable="True"
        Icon="/Assets/avalonia-logo.ico">
    
    <Design.DataContext>
        <viewModels:MainWindowViewModel />
    </Design.DataContext>
    
    <Window.Styles>
        <Style Selector="Button.FileDropZone">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource Primary}" />
            <Setter Property="BorderThickness" Value="4" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Margin" Value="10" />
        </Style>
        <Style Selector="Button.FileDropZone:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BackgroundSecondary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Primary}" />
            <Setter Property="BorderThickness" Value="4" />
        </Style>
        <Style Selector="Button.FileDropZone:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BackgroundSecondary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Primary}" />
            <Setter Property="BorderThickness" Value="4" />
        </Style>
        
        <Style Selector="Button.SquareIconButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource Primary}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Width" Value="{Binding $self.Bounds.Height}" />
        </Style>
        <Style Selector="Button.SquareIconButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BackgroundSecondary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Primary}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Button.SquareIconButton materialIcons|MaterialIcon">
            <Setter Property="Foreground" Value="{DynamicResource Primary}" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Button.SquareIconButton:disabled materialIcons|MaterialIcon">
            <Setter Property="Opacity" Value="0.5" />
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource RobotoMono}" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
        </Style>
        
        <!-- IT SHOULD NOT BE THIS HARD TO STYLE A FUCKING TEXT BOX. -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource BackgroundSecondary}" />
            <Setter Property="FontFamily" Value="{StaticResource RobotoMono}" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource Primary}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TextBox:focus-within">
            <Setter Property="Background" Value="{DynamicResource Secondary}" />
            <Setter Property="Foreground" Value="{DynamicResource BackgroundPrimary}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TextBox:pointerover">
            <Setter Property="Background" Value="{DynamicResource Secondary}" />
            <Setter Property="Foreground" Value="{DynamicResource BackgroundPrimary}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border">
            <Setter Property="Background" Value="{DynamicResource Secondary}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TextBox:pointerpressed /template/ Border">
            <Setter Property="Background" Value="{DynamicResource Secondary}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TextBox:focus-within /template/ Border">
            <Setter Property="Background" Value="{DynamicResource Secondary}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
    </Window.Styles>
    
    <Grid RowDefinitions="Auto Auto 45 *" ColumnDefinitions="* 45">
        <TextBlock Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Margin="9 5 0 0" FontSize="30"
                   Foreground="{DynamicResource Primary}">unimportable</TextBlock>
        <TextBlock Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"  Margin="9 5 0 0" FontSize="15"
                   Foreground="{DynamicResource Secondary}">song directory</TextBlock>
        <TextBox Grid.Column="0" Grid.Row="2" FontSize="15" Margin="4"
                 Text="{Binding CustomSongsDirectoryName}" TextChanged="OnDirectoryPathTextBoxChange" />
        <Button Classes="SquareIconButton" Grid.Column="1" Grid.Row="2"
                Command="{Binding ChooseCustomSongsDirectoryCommand}">
            <materialIcons:MaterialIcon Kind="Folder" IconSize="20" />
        </Button>
        <Button Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2" Classes="FileDropZone" HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" IsEnabled="{Binding CanImportSongs}" Name="SongDropZone"
                Command="{Binding ChooseSongsToImportCommand}">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"
                       Foreground="{DynamicResource Primary}" FontSize="40" Text="{Binding SongDropZoneText}" />
        </Button>
    </Grid>
</Window>